rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function hasActivePlan(data) {
      return data.status == "active"
        && (data.plan == "pro" || data.plan == "elite");
    }

    function hasActiveUidEntitlement() {
      return signedIn()
        && exists(/databases/$(database)/documents/entitlements/$(request.auth.uid))
        && hasActivePlan(get(/databases/$(database)/documents/entitlements/$(request.auth.uid)).data);
    }

    function hasActiveEmailEntitlement() {
      return signedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/emailEntitlements/$(request.auth.token.email.lower()))
        && hasActivePlan(get(/databases/$(database)/documents/emailEntitlements/$(request.auth.token.email.lower())).data);
    }

    function hasActiveCommunityAccess() {
      return isAdmin()
        || hasActiveUidEntitlement()
        || hasActiveEmailEntitlement();
    }

    function safeCommunityPostCreate() {
      return hasActiveCommunityAccess()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "uid",
          "authorName",
          "authorEmail",
          "authorInitials",
          "avatar",
          "badge",
          "role",
          "look",
          "outfit",
          "caption",
          "photo",
          "tags",
          "likedBy",
          "commentCount",
          "createdAt",
          "updatedAt"
        ]);
    }

    function safeCommunityLikeUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likedBy", "updatedAt"])
        && request.resource.data.likedBy.diff(resource.data.likedBy).affectedKeys().hasOnly([request.auth.uid]);
    }

    function safeProblemReportCreate() {
      return request.resource.data.keys().hasOnly([
          "uid",
          "userEmail",
          "contactEmail",
          "type",
          "title",
          "message",
          "page",
          "url",
          "userAgent",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "uid",
          "userEmail",
          "contactEmail",
          "type",
          "title",
          "message",
          "page",
          "url",
          "userAgent",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && (!signedIn() && request.resource.data.uid == "" || signedIn() && request.resource.data.uid == request.auth.uid)
        && request.resource.data.type in ["bug", "not_working", "feature_suggestion", "other"]
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 160
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 3000
        && (request.resource.data.title.size() > 0 || request.resource.data.message.size() > 0)
        && request.resource.data.contactEmail is string
        && request.resource.data.contactEmail.size() <= 180
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() <= 180
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 80
        && request.resource.data.url is string
        && request.resource.data.url.size() <= 600
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 350
        && request.resource.data.status == "open"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function safeProfileWrite(uid) {
      return isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && !request.resource.data.keys().hasAny([
          "admin",
          "isAdmin",
          "role",
          "plan",
          "status",
          "source",
          "entitlement",
          "subscription"
        ]);
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /userProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if safeProfileWrite(uid);
      allow delete: if isAdmin();
    }

    match /entitlements/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /emailEntitlements/{email} {
      allow read: if isAdmin()
        || (signedIn() && request.auth.token.email != null && request.auth.token.email.lower() == email);
      allow create, update, delete: if isAdmin();
    }

    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if safeCommunityPostCreate();
      allow update: if isAdmin() || safeCommunityLikeUpdate();
      allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
    }

    match /problemReports/{reportId} {
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if safeProblemReportCreate();
      allow update, delete: if isAdmin();
    }

    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
  }
}
