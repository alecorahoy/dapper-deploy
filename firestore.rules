rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function hasActivePlan(data) {
      return data.status == "active"
        && (data.plan == "pro" || data.plan == "elite");
    }

    function hasActiveUidEntitlement() {
      return signedIn()
        && exists(/databases/$(database)/documents/entitlements/$(request.auth.uid))
        && hasActivePlan(get(/databases/$(database)/documents/entitlements/$(request.auth.uid)).data);
    }

    function hasActiveEmailEntitlement() {
      return signedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/emailEntitlements/$(request.auth.token.email.lower()))
        && hasActivePlan(get(/databases/$(database)/documents/emailEntitlements/$(request.auth.token.email.lower())).data);
    }

    function hasActiveCommunityAccess() {
      return isAdmin()
        || hasActiveUidEntitlement()
        || hasActiveEmailEntitlement();
    }

    function safeCommunityPostCreate() {
      return hasActiveCommunityAccess()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "uid",
          "authorName",
          "authorEmail",
          "authorInitials",
          "avatar",
          "badge",
          "role",
          "look",
          "outfit",
          "caption",
          "photo",
          "tags",
          "likedBy",
          "commentCount",
          "createdAt",
          "updatedAt"
        ]);
    }

    function safeCommunityLikeUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likedBy", "updatedAt"])
        && request.resource.data.likedBy.diff(resource.data.likedBy).affectedKeys().hasOnly([request.auth.uid]);
    }

    function safeProfileWrite(uid) {
      return isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && !request.resource.data.keys().hasAny([
          "admin",
          "isAdmin",
          "role",
          "plan",
          "status",
          "source",
          "entitlement",
          "subscription"
        ]);
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /userProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if safeProfileWrite(uid);
      allow delete: if isAdmin();
    }

    match /entitlements/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /emailEntitlements/{email} {
      allow read: if isAdmin()
        || (signedIn() && request.auth.token.email != null && request.auth.token.email.lower() == email);
      allow create, update, delete: if isAdmin();
    }

    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if safeCommunityPostCreate();
      allow update: if isAdmin() || safeCommunityLikeUpdate();
      allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
    }

    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
  }
}
